{
  "name": "intel.dom.gob",
  "version": "1.0.0",
  "private": true,
  "description": "INTEL.DOM.GOB — API-first open-source AI platform for Government Intelligence.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "providers",
    "providers/*",
    "services",
    "services/*",
    "apps/*",
    "apps/studio/v0",
    "workers/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "~5.8.2",
    "vitest": "^2.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "express": "^4.19.2",
    "@types/express": "^4.17.21"
  },
  "engines": {
    "node": ">=20"
  }
}
