# INTEL.DOM.GOB MCP server — environment configuration
#
# The MCP server is a pure client of the API gateway. It resolves the API
# URL from DOMAIN + API_PORT (via @intel.dom.gob/config) and authenticates
# with INTEL_API_TOKEN.

# Domain the platform runs on. localhost for development, intel.dom.gob for prod.
DOMAIN=localhost

# API gateway port (reached internally as api:<API_PORT>).
API_PORT=4000

# Port the MCP server listens on.
MCP_PORT=4100

# API token for authenticated calls (Investigador / Pro / Institucional).
# Optional: without it the server still serves the anonymous Público tier,
# but tool calls are limited to that tier's quota.
INTEL_API_TOKEN=

NODE_ENV=development
