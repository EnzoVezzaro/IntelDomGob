# INTEL.DOM.GOB CLI — environment configuration

# MCP server the CLI connects to (Streamable HTTP + SSE).
# Defaults to http://mcp.localhost/mcp when unset.
INTEL_MCP_URL=http://mcp.localhost/mcp

# Optional: local LLM "interpreter" used to rewrite/improve queries before
# sending them to the MCP server. Leave all three blank to disable the
# interpreter — the CLI still works fully through MCP without an LLM.
# When set, these take precedence over the saved ~/.intel/config.json values.
INTEL_LLM_BASE_URL=
INTEL_LLM_API_KEY=
INTEL_LLM_MODEL=
