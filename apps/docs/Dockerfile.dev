# syntax=docker.io/docker/dockerfile:1
#
# Development image for the docs site (apps/docs).
#
# Runs `next dev` with hot-reload instead of the standalone production
# server. The source tree is bind-mounted at runtime (see
# docker-compose.override.yml), so edits to apps/docs/* show up instantly
# at docs.<DOMAIN> — no image rebuild required.
#
# This file is NEVER used in production: deploy.sh builds from the default
# Dockerfile (standalone) and the override is not applied.

FROM node:22-alpine

RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install dependencies once at image build time. node_modules is NOT
# mounted at runtime, so it survives source edits.
COPY package.json ./
RUN npm install --legacy-peer-deps

# Source is mounted read-write by the compose override.
EXPOSE 3000
ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
