# INTEL.DOM.GOB SDK — environment configuration
#
# The SDK is a library: you configure it by passing options to
# createClient({ baseUrl, token }). These are the canonical environment
# variable names used across the platform — read them in your app and pass
# them into createClient().

# Base URL of the INTEL.DOM.GOB API gateway.
INTEL_API_URL=http://api.localhost

# API key/token for authenticated tiers (Investigador / Pro / Institucional).
# Leave blank to use the anonymous Público tier (20 queries/day, no key).
INTEL_API_TOKEN=
