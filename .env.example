# INTEL.DOM.GOB — environment configuration
#
# Copy to `.env` and adjust. The SAME values drive both development and
# production; only DOMAIN changes between environments.

# --- Platform ---
# Development: localhost   (Caddy serves http://studio.localhost etc.)
# Production:  intel.dom.gob (Caddy serves https://studio.intel.dom.gob etc.)
DOMAIN=localhost
NODE_ENV=development
LOG_FORMAT=development

# --- API ---
API_PORT=4000
# Internal docker service name for the search provider.
SEARXNG_URL=http://searxng:8080

# --- AI Provider (Gemini is the default) ---
GEMINI_API_KEY=
DEFAULT_AI_PROVIDER=gemini
AI_PROVIDERS=gemini
DEFAULT_SEARCH_PROVIDER=searxng
SEARCH_PROVIDERS=searxng

# --- Optional AI Providers (registered only when keys are present) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Persistence ---
DATABASE_URL=postgres://intel:intel@postgres:5432/inteldomgob
# DragonflyDB (Redis-compatible) — powers the event bus (Redis Streams).
REDIS_URL=redis://dragonfly:6379
# When true (production by default), /v1 endpoints require a valid API key.
REQUIRE_API_KEY=false

# --- Optional OCR Provider (Unlimited-OCR / OpenOCR HTTP endpoint) ---
UNLIMITED_OCR_URL=
# --- Optional Presentation Provider (HyperFrames) ---
HYPERFRAMES_URL=https://frames.intel.dom.gob

# --- MCP server ---
MCP_PORT=4100
INTEL_API_TOKEN=

# --- Caddy / HTTPS (production only) ---
CADDY_ACME_EMAIL=

# --- Infrastructure ---
POSTGRES_USER=intel
POSTGRES_PASSWORD=intel
POSTGRES_DB=inteldomgob

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=https://studio.localhost,https://studio.intel.dom.gob,https://studio/v0.localhost,https://admin.localhost,https://web.localhost

# --- Studio v1 (Odysseus workspace, git submodule at apps/studio/v1) ---
# Runs on its own compose overlay: docker/studio/v1.compose.yml
# Connects to the platform ONLY via the MCP server (mcp:4100/mcp).
STUDIO_AUTH_ENABLED=true
STUDIO_LOCALHOST_BYPASS=false
STUDIO_SECURE_COOKIES=false
STUDIO_ALLOWED_ORIGINS=
STUDIO_ADMIN_USER=admin
STUDIO_ADMIN_PASSWORD=
# Default MCP server the Studio registers on first boot (connects to our
# INTEL.DOM.GOB platform). Override the name/URL only if self-hosting the MCP.
STUDIO_MCP_NAME=intel-dom-gob
STUDIO_MCP_URL=http://mcp:4100/mcp

# Optional default email account for the Studio (seeded on boot).
# Set STUDIO_EMAIL_SMTP_HOST to enable; the on-boot script writes these into
# Odysseus' settings.json and the built-in migration creates a "Default" account.
STUDIO_EMAIL_SMTP_HOST=
STUDIO_EMAIL_SMTP_PORT=465
STUDIO_EMAIL_SMTP_SECURITY=
STUDIO_EMAIL_SMTP_USER=
STUDIO_EMAIL_SMTP_PASSWORD=
STUDIO_EMAIL_IMAP_HOST=
STUDIO_EMAIL_IMAP_PORT=993
STUDIO_EMAIL_IMAP_USER=
STUDIO_EMAIL_IMAP_PASSWORD=
STUDIO_EMAIL_IMAP_STARTTLS=true
STUDIO_EMAIL_FROM=
