# INTEL.DOM.GOB — environment configuration
#
# Copy to `.env` and adjust. The SAME values drive both development and
# production; only DOMAIN changes between environments.

# --- Platform ---
# Development: localhost   (Caddy serves http://studio.localhost etc.)
# Production:  intel.dom.gob (Caddy serves https://studio.intel.dom.gob etc.)
DOMAIN=localhost
NODE_ENV=development
LOG_FORMAT=development

# --- API ---
API_PORT=4000
# Internal docker service name for the search provider.
SEARXNG_URL=http://searxng:8080

# --- AI Provider (Gemini is the default) ---
GEMINI_API_KEY=
DEFAULT_AI_PROVIDER=gemini
AI_PROVIDERS=gemini
DEFAULT_SEARCH_PROVIDER=searxng
SEARCH_PROVIDERS=searxng

# --- Optional AI Providers (registered only when keys are present) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Persistence ---
DATABASE_URL=postgres://intel:intel@postgres:5432/inteldomgob
# DragonflyDB (Redis-compatible) — powers the event bus (Redis Streams).
REDIS_URL=redis://dragonfly:6379
# When true (production by default), /v1 endpoints require a valid API key.
REQUIRE_API_KEY=false

# --- Optional OCR Provider (Unlimited-OCR / OpenOCR HTTP endpoint) ---
UNLIMITED_OCR_URL=
# --- Optional Presentation Provider (HyperFrames) ---
HYPERFRAMES_URL=https://frames.intel.dom.gob

# --- MCP server ---
MCP_PORT=4100
INTEL_API_TOKEN=

# --- Caddy / HTTPS (production only) ---
CADDY_ACME_EMAIL=

# --- Infrastructure ---
POSTGRES_USER=intel
POSTGRES_PASSWORD=intel
POSTGRES_DB=inteldomgob

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=https://studio.localhost,https://studio.intel.dom.gob,https://admin.localhost,https://web.localhost
